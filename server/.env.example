# --- Cooud (payments) ---
# Dashboard: Store -> Integrations -> Chaves da API v2
COOUD_SECRET_KEY=cooud_sk_sandbox_...
COOUD_API_URL=https://api.cooud.com/v2
COOUD_COMPAT_DATE=2026-09-01
# Dashboard: Store -> Integrations -> Webhooks (copied once at creation time)
COOUD_WEBHOOK_SECRET=whsec_...

# Where the buyer lands after payment (your checkout app, not Shopify)
CHECKOUT_PUBLIC_URL=http://localhost:5173
COOUD_SUCCESS_URL=http://localhost:5173/success
COOUD_CANCEL_URL=http://localhost:5173/cancel

# --- Shopify Admin API (custom app on meli-respuestas.com) ---
# Shopify Admin -> Settings -> Apps and sales channels -> Develop apps
# Scopes needed: read_products, write_orders
SHOPIFY_SHOP_DOMAIN=meli-respuestas.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2025-01

# --- Server ---
PORT=3010
# Comma-separated list of origins allowed to call this API (your storefront + checkout app)
ALLOWED_ORIGINS=http://localhost:5173,https://meli-respuestas.com
