# --- Cooud (payments) ---
# Dashboard: Store -> Integrations -> Chaves da API v2
COOUD_SECRET_KEY=cooud_sk_sandbox_...
COOUD_API_URL=https://api.cooud.com/v2
COOUD_COMPAT_DATE=2026-09-01
# Dashboard: Store -> Integrations -> Webhooks (copied once at creation time)
COOUD_WEBHOOK_SECRET=whsec_...

# Public URL of THIS backend (it now also serves the address-collection page:
# checkout.html/.js under server/public/). In production this must be a real HTTPS domain.
CHECKOUT_PUBLIC_URL=http://localhost:3010
# Where Cooud sends the buyer after payment succeeds/is cancelled. In production point
# these at real pages on your storefront (e.g. a "thank you" page), not this backend.
COOUD_SUCCESS_URL=http://localhost:3010/success.html
COOUD_CANCEL_URL=http://localhost:3010/checkout.html

# --- Shopify Admin API (custom app on your store) ---
# Shopify Admin -> Settings -> Apps and sales channels -> Develop apps
# Scopes needed: read_products, write_orders
# IMPORTANT: must be the *.myshopify.com domain, NOT your custom/primary domain
# (e.g. meli-respuestas.com) — the Admin API only responds on the myshopify.com host.
# Find it in the Shopify Admin URL bar, or via GraphQL: `shop { myshopifyDomain }`.
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2025-01

# --- Server ---
PORT=3010
# Comma-separated list of origins allowed to call this API from the browser — your
# storefront's CUSTOM domain (e.g. https://meli-respuestas.com), since that's the
# origin the buyer's browser sends when checkout-interceptor.js calls this API.
ALLOWED_ORIGINS=https://meli-respuestas.com
